{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "adjust-timeframe.jsx",
              "ai-composer.jsx",
              "calendar/**",
              "connect-app.jsx",
              "connect-modal.jsx",
              "currency-converter.jsx",
              "design-canvas.jsx",
              "dynamic-calendar.jsx",
              "ios-frame.jsx",
              "message-dropdown.jsx",
              "oc-parts.jsx",
              "onboarding-completion.jsx",
              "reader-island.jsx",
              "sprint-planner.jsx",
              "status-card.jsx",
              "task-board.jsx",
              "tweaks-panel.jsx",
              "ui_kits/crm-mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|Material Symbols Outlined|Material Icons))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, Material Symbols Outlined, Material Icons."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
