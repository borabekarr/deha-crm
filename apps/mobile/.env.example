# the data-flow audit is complete (PII review, EU-region endpoint decision).
# EXPO_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
# EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
