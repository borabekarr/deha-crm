{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "expo-fab": ["src/components/vendor/expo-fab"],
      "expo-ios-like-date-picker": ["src/components/vendor/expo-ios-like-date-picker"],
      "ios-like-swipe-actions": ["src/components/vendor/expo-ios-like-swipe-actions"],
      "expo-linear-like-bottom-tabs": ["src/components/vendor/expo-linear-like-bottom-tabs"],
      "expo-motion-tabs": ["src/components/vendor/expo-motion-tabs"],
      "expo-progressive-blur": ["src/components/vendor/expo-progressive-blur"]
    }
  },
  "exclude": [
    "node_modules",
    "src/components/vendor"
  ]
}
