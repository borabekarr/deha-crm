      "form-data": "^4.0.5",
      "axios": "^1.16.1",
      "minimatch@<3.1.4": "^3.1.4",
      "esbuild@<0.25.0": "^0.25.0",
      "uuid@<11.1.1": "^11.1.1",
      "tmp@<0.2.4": "^0.2.4",
      "react": "19.2.7",
      "react-dom": "19.2.7"
