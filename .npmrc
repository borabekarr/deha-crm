minimum-release-age=1440
block-exotic-subdeps=true
# Allow @shopify/react-native-skia to run its install script (native build helper)
build-scripts-allowlist[]=@shopify/react-native-skia
# Hoist react and react-native to root to prevent duplicate native module copies
# that cause expo-doctor duplicate-native-deps failures in pnpm monorepos.
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*react-native*
